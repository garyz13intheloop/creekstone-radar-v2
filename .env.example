# ── LLM ──────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-flash-1.5
LLM_TIMEOUT=60

# ── X / Twitter (OAuth 1.0a) ──────────────────────────────────────────────────
X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret
X_ACCESS_TOKEN=your-x-access-token
X_ACCESS_TOKEN_SECRET=your-x-access-token-secret

# ── Product Hunt ──────────────────────────────────────────────────────────────
PRODUCTHUNT_DEVELOPER_TOKEN=your-producthunt-token

# ── GitHub (optional but recommended for higher rate limits) ──────────────────
GITHUB_TOKEN=ghp_your-github-token

# ── Reddit (register at https://www.reddit.com/prefs/apps, free) ─────────────
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=CreekstoneRadar/2.0

# ── Sources to enable (comma-separated) ──────────────────────────────────────
ENABLED_SOURCES=producthunt,github_trending,github_events,hackernews,openrouter,huggingface,x_twitter,reddit

# ── Thresholds ────────────────────────────────────────────────────────────────
GITHUB_STARS_SPIKE_THRESHOLD=200
OPENROUTER_WOW_THRESHOLD=50
X_MIN_LIKES=20
X_MAX_RESULTS=50
REDDIT_MIN_UPVOTES=30
